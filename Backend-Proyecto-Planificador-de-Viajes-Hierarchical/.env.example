# Modelo LLM a usar
MODEL=gpt-5.1

# Clave de OpenAI
OPENAI_API_KEY=sk-...

# Clave de Tavily (motor de búsqueda de los agentes). Gratis en https://tavily.com
TAVILY_API_KEY=tvly-...

# Token de la Plataforma de CrewAI (Settings -> Integrations en app.crewai.com)
# Necesario para la integración con Google Calendar.
CREWAI_PLATFORM_INTEGRATION_TOKEN=PK_...

# Conexión directa a Postgres de Supabase (Project Settings -> Database ->
# Connection parameters -> "Session pooler"), para persistir el historial de
# chat (tabla chat_messages, ver db.py). No es el cliente REST de Supabase:
# se conecta directo con asyncpg, así que solo hacen falta estos 5 valores.
DB_USER=postgres.xxxxxxxx
DB_PASSWORD=...
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
