# Modelo LLM a usar
MODEL=gpt-5.1

# Clave de OpenAI
OPENAI_API_KEY=sk-...

# Clave de Tavily (motor de búsqueda de los agentes). Gratis en https://tavily.com
TAVILY_API_KEY=tvly-...

# Token de la Plataforma de CrewAI (Settings -> Integrations en app.crewai.com)
# Necesario para la integración con Google Calendar.
CREWAI_PLATFORM_INTEGRATION_TOKEN=PK_...
